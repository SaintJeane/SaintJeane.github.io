---
// src/components/Nav.astro
// ─── Sticky top navigation ──────────────────────────────────────────────────
// Transparent at top → gains blur + border on scroll.
// 🔧 Replace placeholder LinkedIn and HuggingFace URLs with real ones.
---

<nav class="nav" id="nav" role="navigation" aria-label="Main navigation">
  <div class="container nav-inner">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Home">
      <span class="logo-bracket">[</span>PJ<span class="logo-bracket">]</span>
    </a>

    <!-- Section links -->
    <ul class="nav-links" role="list">
      <li><a href="/#projects" class="nav-link">Projects</a></li>
      <li><a href="/#skills"   class="nav-link">Skills</a></li>
      <li><a href="/#about"    class="nav-link">About</a></li>
    </ul>

    <!-- External icon links -->
    <div class="nav-social">

      <!-- GitHub -->
      <a href="https://github.com/SaintJeane" class="nav-icon"
         aria-label="GitHub" target="_blank" rel="noopener noreferrer">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.167 6.839 9.49.5.092.682-.217.682-.483 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .269.18.58.688.482A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/peterjaimbo" class="nav-icon"
         aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- HuggingFace (text monogram — no official icon in Simple Icons) -->
      <a href="https://huggingface.co/Saint5" class="nav-icon"
         aria-label="HuggingFace" target="_blank" rel="noopener noreferrer">
        <span class="hf-badge" aria-hidden="true">HF</span>
      </a>

    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    const toggle = () => nav.classList.toggle('scrolled', window.scrollY > 20);
    window.addEventListener('scroll', toggle, { passive: true });
    toggle();
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background var(--t), border-color var(--t), backdrop-filter var(--t);
  }
  .nav.scrolled {
    background: rgba(10, 12, 18, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 4rem;
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    transition: color var(--t);
  }
  .nav-logo:hover { color: var(--accent); }
  .logo-bracket { color: var(--accent); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    margin-right: auto;
  }
  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-2);
    padding: 0.4rem 0.8rem;
    border-radius: var(--r-sm);
    transition: color var(--t), background var(--t);
  }
  .nav-link:hover { color: var(--text); background: var(--surface); }

  .nav-social {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }
  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: var(--r-sm);
    color: var(--text-2);
    transition: color var(--t), background var(--t);
  }
  .nav-icon:hover { color: var(--accent); background: var(--accent-glow); }

  .hf-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  @media (max-width: 540px) { .nav-links { display: none; } }
</style>
