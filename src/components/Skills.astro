---

<section class="section skills-section" id="skills">
  <div class="container">

    <header class="section-header">
      <h2>Skills & Technologies</h2>
      <p>
        Tools, frameworks, and platforms I work with across ML engineering,
        data science, and full-stack development.
      </p>
    </header>

    <!--
      2-column grid: categories render in reading order left-to-right.
      On mobile this collapses to a single column (see @media below).
    -->
    <div class="skills-grid">
      {categories.map(cat => (
        <div class="category">
          <p class="cat-label">{cat.name}</p>
          <div class="badge-row">
            {cat.badges.map(b => (
              <img
                src={b.src}
                alt={b.alt}
                title={b.alt}
                loading="lazy"
                decoding="async"
                class="skill-badge"
              />
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Section header ── */
  .section-header {
    margin-bottom: 2.5rem;
  }
  .section-header h2 {
    margin-bottom: 0.6rem;
  }
  .section-header p {
    font-size: 1rem;
    color:      var(--text-2);
    max-width:  60ch;
  }

  /* ── 2-column category grid ── */
  .skills-grid {
    display:               grid;
    grid-template-columns: 1fr 1fr;
    gap:                   2.5rem 3.5rem;
  }

  /* ── Category cell ── */
  .cat-label {
    font-family:    var(--font-mono);
    font-size:      0.68rem;
    color:          var(--accent);      /* accent indigo — makes labels pop */
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom:  0.65rem;
    max-width:      none;               /* override global p max-width */
  }

  /* ── Badge rows wrap naturally ── */
  .badge-row {
    display:   flex;
    flex-wrap: wrap;
    gap:       0.4rem 0.35rem;
    align-items: flex-start;
  }

  /* ── Individual shield badge ── */
  .skill-badge {
    display:       block;
    height:        26px;              /* consistent height; width auto-scales */
    width:         auto;
    border-radius: 4px;
    transition:    transform var(--t), opacity var(--t);
    flex-shrink:   0;                 /* don't compress badges */
  }
  .skill-badge:hover {
    transform: translateY(-2px);
    opacity:   0.88;
  }

  /* ── Mobile: single column ── */
  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
      gap:                   2rem;
    }
  }
</style>
