---
// src/components/ProjectCard.astro
// ─── Project card used in the home-page projects grid ───────────────────────
//
// Layout (top → bottom inside the card):
//   - Status badge (Live Demo / GitHub) + year
//   - Project title
//   - Tagline
//   - Tech tags (max 5 shown; overflow shown as "+N")
//   - Action links (View Project / GitHub)
//
// Live-demo cards get a subtle accent corner glow via ::before.

import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { slug, title, tagline, tech, hfSpace, github, status, year } = project;

// A card is "live" when it has a deployed Space and status is 'live'
const isLive = status === 'live' && !!hfSpace;

// Show at most 5 tags to keep cards a consistent height; excess shown as "+N"
const visibleTech = tech.slice(0, 5);
const extraCount  = tech.length - visibleTech.length;
---

<article class:list={['card', { 'card--live': isLive }]}>

  <!-- Top row: badge on the left, year on the right -->
  <div class="card-top">
    {isLive
      ? <span class="badge-live">Live Demo</span>
      : <span class="badge-static">GitHub</span>
    }
    <span class="card-year">{year}</span>
  </div>

  <!-- Title -->
  <h3 class="card-title">{title}</h3>

  <!-- Short tagline — uses flex: 1 to push tags/links to the bottom -->
  <p class="card-desc">{tagline}</p>

  <!-- Tech tags -->
  <div class="card-tags" aria-label="Technologies used">
    {visibleTech.map(t => <span class="tag">{t}</span>)}
    {extraCount > 0 && <span class="tag tag-extra">+{extraCount}</span>}
  </div>

  <!-- Links:
       If the project has a Space → "View Project" goes to the full project page (with embed).
       Otherwise → primary button goes directly to GitHub.                                    -->
  <div class="card-links">
    {hfSpace
      ? (
        <a href={`/projects/${slug}`} class="btn btn-primary btn-sm">
          View Project →
        </a>
      ) : (
        <a href={github} class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer">
          View on GitHub →
        </a>
      )
    }
    {github && hfSpace && (
      <a href={github} class="btn btn-ghost btn-sm" target="_blank" rel="noopener noreferrer">
        GitHub ↗
      </a>
    )}
  </div>

</article>

<style>
  /* ── Card shell ── */
  .card {
    background:    var(--surface);
    border:        1px solid var(--border);
    border-radius: var(--r-lg);
    padding:       1.5rem;
    display:       flex;
    flex-direction: column;
    gap:           1rem;
    position:      relative;
    overflow:      hidden;
    transition:
      border-color var(--t),
      background   var(--t),
      transform    var(--t),
      box-shadow   var(--t);
  }

  /*
    Subtle accent radial glow in the top-left corner for cards with a live demo.
    Uses ::before so it doesn't affect the card's layout flow.
  */
  .card--live::before {
    content:        '';
    position:       absolute;
    top:            0;
    left:           0;
    width:          160px;
    height:         160px;
    background:     radial-gradient(circle at 0% 0%, var(--accent-glow-2), transparent 70%);
    pointer-events: none;
  }

  /* Hover: lift + brighten border */
  .card:hover {
    border-color: var(--border-2);
    background:   var(--surface-2);
    transform:    translateY(-3px);
    box-shadow:   0 8px 32px rgba(0, 0, 0, 0.35);
  }

  /* ── Top row ── */
  .card-top {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
  }

  /* "GitHub" badge (non-live card) */
  .badge-static {
    display:       inline-flex;
    align-items:   center;
    font-size:     0.68rem;
    font-family:   var(--font-mono);
    font-weight:   500;
    padding:       0.22em 0.7em;
    border-radius: 999px;
    background:    var(--surface-2);
    color:         var(--text-muted);
    border:        1px solid var(--border-2);
    text-transform:  uppercase;
    letter-spacing:  0.06em;
  }

  .card-year {
    font-family: var(--font-mono);
    font-size:   0.72rem;
    color:       var(--text-muted);
  }

  /* ── Title ── */
  .card-title {
    font-size:      1.15rem;
    font-weight:    600;
    letter-spacing: -0.01em;
    color:          var(--text);
    line-height:    1.3;
  }

  /* ── Tagline ── */
  /* flex: 1 makes this grow to fill available space, pushing links to bottom */
  .card-desc {
    font-size:   0.9rem;
    color:       var(--text-2);
    line-height: 1.65;
    flex:        1;
    max-width:   none;
  }

  /* ── Tags ── */
  .card-tags {
    display:   flex;
    flex-wrap: wrap;
    gap:       0.4rem;
  }

  /* "+N more" overflow indicator */
  .tag-extra {
    background:   transparent;
    border-color: var(--border-2);
    color:        var(--text-muted);
  }

  /* ── Action links ── */
  .card-links {
    display:   flex;
    gap:       0.5rem;
    flex-wrap: wrap;
    margin-top: auto;   /* sticks to the bottom of the card */
  }
</style>
