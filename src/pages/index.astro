---
// src/pages/index.astro
// ─── Home page ───────────────────────────────────────────────────────────────
//
// Sections (in order):
//   1. Nav          — sticky top bar (imports from Nav.astro)
//   2. Hero         — name, role, terminal meta line, bio, CTAs
//   3. Projects     — responsive card grid from projects.ts
//   4. Skills       — shields.io badge grid, grouped by category
//   5. About        — bio, social badges (SocialLinks.astro), quick stats
//   6. Footer

import Layout       from '../layouts/Layout.astro';
import Nav          from '../components/Nav.astro';
import Hero         from '../components/Hero.astro';
import ProjectCard  from '../components/ProjectCard.astro';
import Skills       from '../components/Skills.astro';
import SocialLinks  from '../components/SocialLinks.astro';
import Footer       from '../components/Footer.astro';
import { projects } from '../data/projects';

// Sort: featured projects first, then newest-first within each group
const sorted = [...projects].sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return b.year - a.year;
});
---

<Layout
  title="Peter Jaimbo - ML & AI Engineer"
  description="Portfolio of Peter Jaimbo: agentic AI systems, ML pipelines, and developer tools — with live demos on HuggingFace Spaces."
>
  <Nav />

  <!-- ── 1. Hero ─────────────────────────────────────────────────────────── -->
  <Hero
    name="Peter Jaimbo"
    role="ML & AI Engineer"
    bio="I build agentic AI systems, ML pipelines, and developer tools — with a focus on making powerful models work efficiently in resource-constrained environments."
    github="https://github.com/SaintJeane"
    huggingface="https://huggingface.co/Saint5"
  />

  <!-- ── 2. Projects ───────────────────────────────────────────────────────
       id="projects" is the scroll target for the nav link + hero CTA.     -->
  <section class="section" id="projects">
    <div class="container">

      <header class="section-header">
        <h2>Projects</h2>
        <p>
          ML and AI systems built end-to-end — from data pipelines to deployed interfaces.
          Cards marked <span class="live-hint">Live Demo</span> have an interactive
          HuggingFace Space embedded on their project page.
        </p>
      </header>

      <div class="projects-grid">
        {sorted.map(project => (
          <ProjectCard project={project} />
        ))}
      </div>

    </div>
  </section>

  <!-- ── 3. Skills ─────────────────────────────────────────────────────────
       Self-contained section; id="skills" lives inside Skills.astro.      -->
  <Skills />

  <!-- ── 4. About ──────────────────────────────────────────────────────────
       id="about" is the scroll target for the nav link.                   -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-wrap">

        <h2>About</h2>

        <div class="about-body">
          <p>
            I'm Peter Jaimbo, a self-directed ML & AI engineer with a passion for building
            systems that actually work in production — not just in notebooks. My work spans
            agentic LLM pipelines, classical ML optimisation, data engineering, and
            full-stack developer tooling, with a recurring focus on making large models
            practical under compute and budget constraints.
          </p>
          <p>
            Currently deepening expertise in agentic RAG architectures, MLOps with Airflow
            and MLflow, and large-scale data processing with PySpark. Every project in this
            portfolio is built to a production standard: documented, deployed, and
            interactive — you can run the live demos directly above.
          </p>
          <p>
            Open to ML engineering, data science, and applied AI roles. Feel free to reach
            out through any of the channels below.
          </p>
        </div>

        <!-- Social profile badges — update URLs in SocialLinks props below -->
        <div class="connect-block">
          <p class="connect-label">Connect</p>
          <SocialLinks
            linkedin="https://linkedin.com/in/peterjaimbo"
            github="https://github.com/SaintJeane"
            huggingface="https://huggingface.co/Saint5"
            kaggle="https://kaggle.com/mylesskews"
            medium="https://medium.com/@mylesskews999"
            email="mailto:jaimbopeter1@gmail.com"
          />
        </div>

        <!-- Quick-stats row -->
        <dl class="about-stats">
          <div class="stat">
            <dt class="stat-label">Focus</dt>
            <dd class="stat-value">Agentic AI &amp; ML Engineering</dd>
          </div>
          <div class="stat">
            <dt class="stat-label">Core stack</dt>
            <dd class="stat-value">Python · PyTorch · LangGraph · AWS</dd>
          </div>
          <div class="stat">
            <dt class="stat-label">Status</dt>
            <dd class="stat-value">Open to opportunities</dd>
          </div>
        </dl>

      </div>
    </div>
  </section>

  <!-- ── 5. Footer — update social URLs to match SocialLinks above ───────── -->
  <Footer
    name="Peter Jaimbo"
    github="https://github.com/SaintJeane"
    linkedin="https://linkedin.com/in/peterjaimbo"
    huggingface="https://huggingface.co/Saint5"
    kaggle="https://kaggle.com/mylesskews"
    medium="https://medium.com/@mylesskews999"
    email="mailto:jaimbopeter1@gmail.com"
  />

</Layout>

<style>
  /* ── Shared section header (Projects + About) ── */
  .section-header {
    margin-bottom: 2.5rem;
  }
  .section-header h2 {
    margin-bottom: 0.6rem;
  }
  .section-header p {
    font-size: 1rem;
    max-width: 60ch;
    color:     var(--text-2);
  }

  /* Inline "Live Demo" span — matches the green live badge colour */
  .live-hint {
    color:       var(--live);
    font-family: var(--font-mono);
    font-size:   0.8em;
  }

  /* ── Projects grid ──
     auto-fill + minmax: fills columns naturally, collapses on mobile.     */
  .projects-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap:                   1.5rem;
  }

  /* ── About section ── */
  .about-wrap {
    max-width: 700px;
  }
  .about-wrap h2 {
    margin-bottom: 1.5rem;
  }

  .about-body {
    display:        flex;
    flex-direction: column;
    gap:            1rem;
    margin-bottom:  2rem;
  }
  .about-body p {
    max-width: none;   /* override global p max-width: 65ch */
    color:     var(--text-2);
  }

  /* ── Connect / social badges block ── */
  .connect-block {
    margin-bottom: 2rem;
  }
  .connect-label {
    font-family:    var(--font-mono);
    font-size:      0.68rem;
    color:          var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom:  0.65rem;
    max-width:      none;
  }

  /* ── Quick stats ── */
  .about-stats {
    display:      flex;
    flex-wrap:    wrap;
    gap:          1.5rem 3rem;
    border-top:   1px solid var(--border);
    padding-top:  1.75rem;
  }
  .stat {
    display:        flex;
    flex-direction: column;
    gap:            0.25rem;
  }
  .stat-label {
    font-family:    var(--font-mono);
    font-size:      0.68rem;
    color:          var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .stat-value {
    font-size:   0.95rem;
    font-weight: 500;
    color:       var(--text);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
